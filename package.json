{
  "name": "alrevolutum-website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "dev:cloudflare": "npx astro build && npx wrangler dev",
    "clean:cache": "rm -rf node_modules/.astro/assets && rm -rf .astro",
    "deploy:cloudflare": "npm run clean:cache && npx astro build && npx wrangler deploy",
    "deploy:preview": "npm run clean:cache && npx astro build && npx wrangler versions upload",
    "build": "astro build",
    "build:ci": "npx playwright install --with-deps chromium && npm run build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/cloudflare": "14.0.1",
    "@astrojs/markdown-remark": "7.2.0",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "astro": "7.0.3",
    "mdast-util-to-string": "4.0.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "7.1.0",
    "sharp": "0.35.2"
  },
  "devDependencies": {
    "playwright": "1.61.1",
    "rehype-mermaid": "3.0.0",
    "vitest": "4.1.9",
    "wrangler": "4.105.0"
  }
}
